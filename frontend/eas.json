{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://vylnax.onrender.com",
        "EXPO_USE_FAST_RESOLVER": "1"
      },
      "channel": "preview"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://vylnax.onrender.com",
        "EXPO_USE_FAST_RESOLVER": "1"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
